{
  "name": "cacheability",
  "description": "A utility class to parse, store and print http cache headers.",
  "version": "4.0.31",
  "author": "miami-man",
  "license": "MIT",
  "homepage": "https://github.com/badbatch/cacheability",
  "repository": {
    "type": "git",
    "url": "https://github.com/badbatch/cacheability.git"
  },
  "bugs": "https://github.com/badbatch/cacheability/issues",
  "type": "module",
  "main": "./dist/esm/index.mjs",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/types/esm/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": {
        "import": "./dist/types/esm/index.d.ts",
        "require": "./dist/types/cjs/index.d.cts"
      },
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm run clean:dist && pnpm run compile",
    "clean:deps": "del-cli ./node_modules",
    "clean:dist": "del-cli ./dist",
    "compile": "pnpm run /^compile:.*/",
    "compile:cjs": "MODULE_SYSTEM=cjs rollup -c ./rollup.config.mjs",
    "compile:esm": "rollup -c ./rollup.config.mjs",
    "compile:types": "tsc --project ./tsconfig.build.json && cts-types build dist/types/esm dist/types/cjs",
    "cut:changelog": "changelog",
    "format": "prettier . --check",
    "installActivateMise": "sh shellScripts/installActivateMise.sh",
    "lint": "pnpm run /^lint:.*/",
    "lint:code": "eslint .",
    "lint:docs": "markdownlint-cli2 --config \".markdownlint.json\" \"**/*.md\" \"!**/node_modules/**\"",
    "prepare": "husky",
    "repodog": "repodog",
    "syncpack": "syncpack format --check && syncpack lint",
    "test": "COMPILER=swc node --require=suppress-experimental-warnings --experimental-vm-modules node_modules/jest/bin/jest.js",
    "type-check": "tsc --noEmit",
    "validate": "pnpm run syncpack && pnpm run build && pnpm run lint && pnpm run type-check && pnpm run test"
  },
  "dependencies": {
    "@types/lodash-es": "^4.17.12",
    "core-js": "^3.49.0",
    "lodash-es": "^4.18.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@jest/globals": "^30.4.1",
    "@repodog/cli": "^1.6.57",
    "@repodog/commitlint-config": "^21.0.2",
    "@repodog/eslint-config": "^9.0.29",
    "@repodog/eslint-config-jest": "^9.0.9",
    "@repodog/jest-config": "^30.0.2",
    "@repodog/markdownlint-config": "^1.2.7",
    "@repodog/prettier-config": "^3.0.5",
    "@repodog/rollup-config": "^4.0.15",
    "@repodog/swc-config": "^1.0.15",
    "@repodog/syncpack-config": "^15.0.3",
    "@repodog/ts-config": "^6.0.3",
    "@rollup/plugin-swc": "^0.4.1",
    "@swc/core": "^1.15.43",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.2",
    "cts-types": "^0.0.11",
    "del-cli": "^7.0.0",
    "eslint": "^9.39.4",
    "generate-changelog": "^1.8.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-environment-node": "^30.4.1",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.4",
    "rollup": "^4.62.2",
    "suppress-experimental-warnings": "^2.0.0",
    "syncpack": "^15.3.2",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "cacheability",
    "cacheControl",
    "etag",
    "headers",
    "http",
    "parser"
  ]
}
